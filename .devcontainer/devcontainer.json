{
  "name": "Divvy Data Engineering",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/divvy-capstone",
  "overrideCommand": false,

  "features": {
    "ghcr.io/devcontainers/features/docker-cli": "latest"
  },

  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml"
      ]
    }
  },

  "forwardPorts": [8080, 8888],

  "postCreateCommand": "pip install -r requirements.txt",
  "postStartCommand": "docker compose up -d postgres kestra",

  "remoteUser": "vscode"
}